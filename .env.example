# MongoDB connection string
# Local: mongodb://localhost:27017/cpr-foodies
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cpr-foodies
MONGODB_URI=mongodb://localhost:27017/cpr-foodies

# NextAuth
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Public key (same as RAZORPAY_KEY_ID) - exposed to the browser for checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Seed script - default admin credentials (change after first login)
ADMIN_EMAIL=admin@cprfoodies.com
ADMIN_PASSWORD=Admin@123
